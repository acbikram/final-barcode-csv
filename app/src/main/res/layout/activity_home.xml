<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121A24">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INVENTORY CONTROL"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#00E676"
        android:layout_marginTop="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Warehouse Scanner Management Console"
        android:textSize="14sp"
        android:textColor="#A0A0A0"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECT TAG TYPE"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgTagType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton android:id="@+id/rbTagA4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A4" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbTag4pcs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4PCS" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbTagVeg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VEG" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbTag4pcsDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4PCS_DATE" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbTag4pcsSame" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4PCS_SAME" android:textColor="#FFFFFF"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECT UNIT TYPE"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgUnitType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton android:id="@+id/rbUnitPcs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PCS" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbUnitPkt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PKT" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbUnitCtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CTN" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbUnitKgs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KGS" android:textColor="#FFFFFF"/>
    </RadioGroup>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchDuplicateChecking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Prevent duplicate scans"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnStartScan"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="START SCAN PIPELINE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#00E676"
        android:textColor="#121A24"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnViewHistory"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="LOGGED HISTORY &amp; EXPORTS"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#00E676"
        android:background="@drawable/button_outline" />

</LinearLayout>
